{
  "name": "claude-traffic-light",
  "version": "1.0.0",
  "description": "A cute desktop traffic light widget that shows Claude Code's working status",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "generate-icons": "node scripts/generate-icon.js"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.7.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.claude-traffic-light.app",
    "productName": "Claude Traffic Light",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "sign": false
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    },
    "portable": {
      "artifactName": "Claude-Traffic-Light-Portable.exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ]
  }
}
